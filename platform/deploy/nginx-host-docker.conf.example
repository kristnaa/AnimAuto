# Host nginx in front of Docker (manim.enfec.cloud → localhost:8088)
# Install:
#   sudo cp nginx-host-docker.conf.example /etc/nginx/sites-available/manimations-studio
#   sudo ln -sf /etc/nginx/sites-available/manimations-studio /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name manim.enfec.cloud;

    client_max_body_size 500M;

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 600s;
    }
}

# If Caddy sits in front of Docker instead of nginx, add to the Caddyfile:
#   reverse_proxy localhost:8088 {
#       transport http {
#           read_timeout 10m
#           write_timeout 10m
#       }
#   }

# After certbot: certbot --nginx -d manim.enfec.cloud
